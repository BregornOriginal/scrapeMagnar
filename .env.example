# Copy this file to .env and adjust as needed. All variables are optional;
# the scraper falls back to sensible defaults when a variable is not set.

# Target JSF page to scrape.
BASE_URL=https://publico.oefa.gob.pe/repdig/consulta/consultaTfa.xhtml

# Number of rows requested per page from the results table.
PAGE_SIZE=10

# Delay (ms) between consecutive PDF downloads, to avoid overloading the server.
DOWNLOAD_DELAY_MS=1000

# Max retry attempts for transient errors (e.g. HTTP 429) before giving up.
MAX_RETRIES=5

# Max number of result pages to process. Use 1 to only scrape the first page.
# 0 means no limit (scrape until there are no more pages).
MAX_PAGES=0

# Local folder where documents.json, failed-downloads.json and pdfs/ are written.
OUTPUT_FOLDER=output
